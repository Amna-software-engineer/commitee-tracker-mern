# Copy this file to .env and fill in your own values.

# Port the Express server listens on
PORT=5000

# Local MongoDB (default if you run `mongod` locally):
MONGODB_URI=mongodb://127.0.0.1:27017/committee_tracker

# ...or a MongoDB Atlas connection string instead, e.g.:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/committee_tracker

# Comma-separated list of origins allowed to call this API (your frontend's dev URL)
CLIENT_ORIGIN=http://localhost:5173
